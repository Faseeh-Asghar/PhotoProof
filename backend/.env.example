# PhotoProof Backend Environment Variables
# Copy this to .env and fill in real values

# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Supabase) ──────────────────────────────────
# Get this from: Supabase > Settings > Database > Connection String > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Redis (Upstash) ─────────────────────────────────────
# Get this from: upstash.com > Create Database > Redis URL
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# ─── Email (Resend) ──────────────────────────────────────
# Get this from: resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ─── Admin Account ────────────────────────────────────────
ADMIN_EMAIL=faseehasghar167@gmail.com
ADMIN_PASSWORD=Admin@PhotoProof2024

# ─── Frontend URL (CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Image Processing ────────────────────────────────────
# Get this from: fapihub.com (optional - for AI background removal)
FAPIHUB_API_KEY=
USE_BG_REMOVAL=false
